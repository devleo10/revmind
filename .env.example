# Server
PORT=3001
NODE_ENV=development

# Comma-separated frontend origins for CORS (defaults: localhost:5173 and :3000)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# LLM — set one (OpenAI or Anthropic)
OPENAI_API_KEY=your_openai_api_key_here

# SQLite (created by seed script on startup)
DATABASE_PATH=./data/novabite.db

# Frontend (Vite / CRA) — API base URL when running locally
VITE_API_URL=http://localhost:3001
